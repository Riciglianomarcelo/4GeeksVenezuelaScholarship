<%- include('partials/layout-head', { title: 'Dashboard' }) %>

<h1>Panel admin</h1>
<p class="muted">Gestión de postulantes, transparencia del fondo, donaciones y fechas de cohortes.</p>

<h2>Resumen del fondo</h2>
<div class="card">
  <form method="POST" action="/admin/stats">
    <div class="row">
      <div>
        <label>Comprometido hasta ahora por 4Geeks (USD)</label>
        <input type="number" step="0.01" name="fund_goal" value="<%= stats.fund_goal %>">
      </div>
      <div>
        <label>Empresas aliadas donando equipos</label>
        <input type="number" name="empresas_aliadas" value="<%= stats.empresas_aliadas %>">
      </div>
      <div>
        <label>Becas otorgadas</label>
        <input type="number" name="becas_otorgadas" value="<%= stats.becas_otorgadas %>">
      </div>
      <div>
        <label>Equipos entregados</label>
        <input type="number" name="equipos_entregados" value="<%= stats.equipos_entregados %>">
      </div>
    </div>
    <p class="muted">"Postulantes" y "personas beneficiadas" se calculan solos a partir de la lista de postulantes de abajo (no se editan aquí).</p>

    <label style="margin-top:12px;">Distribución del fondo (hasta 4 categorías, deben sumar 100)</label>
    <% const bd = stats.breakdown || []; for(let i=0;i<4;i++){ const row = bd[i] || {}; %>
      <div class="row">
        <input type="text" name="bd_label_<%= i %>" placeholder="Categoría" value="<%= row.label || '' %>">
        <input type="number" name="bd_pct_<%= i %>" placeholder="%" value="<%= row.pct || '' %>">
      </div>
    <% } %>
    <button type="submit">Guardar cambios</button>
  </form>
</div>

<h2>Postulantes (<%= applicants.length %>)</h2>
<div class="card">
  <a href="/admin/applicants/new" class="btn">+ Nuevo postulante</a>
  <table style="margin-top:16px;">
    <thead>
      <tr><th>Nombre público</th><th>Ubicación</th><th>Necesidades</th><th>Estado</th><th>Visibilidad</th><th>Origen</th><th></th></tr>
    </thead>
    <tbody>
      <% applicants.forEach(a => { %>
      <tr>
        <td><b><%= a.public_name %></b><br><span class="muted"><%= a.full_name || '' %></span></td>
        <td><%= a.location || '—' %><% if(a.age){ %> · <%= a.age %> años<% } %></td>
        <td><% (Array.isArray(a.needs) ? a.needs : []).forEach(n => { %><span class="pill-inline"><%= n %></span><% }) %></td>
        <td><%= a.status %></td>
        <td><span class="badge <%= a.is_public ? 'badge-public' : 'badge-private' %>"><%= a.is_public ? 'Pública' : 'Privada' %></span></td>
        <td><%= a.source %></td>
        <td>
          <a href="/admin/applicants/<%= a.id %>/edit" class="btn secondary">Editar</a>
          <form class="inline" method="POST" action="/admin/applicants/<%= a.id %>/delete" onsubmit="return confirm('¿Eliminar este postulante?')">
            <button type="submit" class="danger">Eliminar</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<h2>Donaciones recientes</h2>
<div class="card">
  <table>
    <thead><tr><th>Fecha</th><th>Monto</th><th>Método</th><th>Donante</th><th>Nota / Persona</th><th></th></tr></thead>
    <tbody>
      <% donations.forEach(d => { %>
      <tr>
        <td><%= new Date(d.created_at).toLocaleDateString('es-VE') %></td>
        <td>$<%= Number(d.amount).toLocaleString('en-US') %></td>
        <td><%= d.method %></td>
        <td><%= d.donor_name || '—' %></td>
        <td><%= d.public_name || d.donor_note || 'Fondo general' %></td>
        <td>
          <form class="inline" method="POST" action="/admin/donations/<%= d.id %>/delete" onsubmit="return confirm('¿Eliminar esta donación?')">
            <button type="submit" class="danger">Eliminar</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>

  <h2 style="margin-top:24px;">Registrar donación manual (Zelle, efectivo, etc.)</h2>
  <form method="POST" action="/admin/donations/manual">
    <div class="row">
      <div>
        <label>Monto (USD)</label>
        <input type="number" step="0.01" name="amount" required>
      </div>
      <div>
        <label>Método</label>
        <select name="method">
          <option value="zelle">Zelle</option>
          <option value="stripe">Stripe (manual)</option>
          <option value="other">Otro</option>
        </select>
      </div>
      <div>
        <label>Nombre del donante (opcional)</label>
        <input type="text" name="donor_name">
      </div>
      <div>
        <label>Postulante a apoyar (opcional)</label>
        <select name="applicant_id">
          <option value="">— Fondo general —</option>
          <% applicants.forEach(a => { %>
            <option value="<%= a.id %>"><%= a.public_name %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <label>Nota</label>
    <textarea name="donor_note" rows="2"></textarea>
    <button type="submit">Registrar donación</button>
  </form>
</div>

<h2>Próximas fechas / cohortes</h2>
<div class="card">
  <table>
    <thead><tr><th>Programa</th><th>Modalidad</th><th>Fecha</th><th>Estado</th><th></th></tr></thead>
    <tbody>
      <% dates.forEach(d => { %>
      <tr>
        <td><%= d.programa %></td>
        <td><%= d.modalidad || '—' %></td>
        <td><%= d.fecha %></td>
        <td><%= d.abierto ? 'Abierto' : 'Cerrado' %></td>
        <td>
          <form class="inline" method="POST" action="/admin/dates/<%= d.id %>/delete" onsubmit="return confirm('¿Eliminar esta fecha?')">
            <button type="submit" class="danger">Eliminar</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>

  <h2 style="margin-top:24px;">Agregar fecha</h2>
  <form method="POST" action="/admin/dates/new">
    <div class="row">
      <input type="text" name="programa" placeholder="Programa (ej. AI Engineering)" required>
      <input type="text" name="modalidad" placeholder="Modalidad (ej. 24 semanas)">
      <input type="text" name="fecha" placeholder="Fecha (ej. Septiembre 2026)">
      <label><input type="checkbox" name="abierto" checked style="width:auto;display:inline-block;"> Inscripciones abiertas</label>
    </div>
    <button type="submit">Agregar</button>
  </form>
</div>

<%- include('partials/layout-foot') %>
