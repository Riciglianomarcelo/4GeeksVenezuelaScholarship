<%- include('partials/layout-head', { title: 'Donaciones de equipos' }) %>

<h1>Donaciones de equipos ofrecidas</h1>
<a href="/admin" class="muted">&larr; Volver al dashboard</a>
<p class="muted" style="margin-top:8px;">Equipos que empresas o personas ofrecieron donar desde el sitio público. Coordina la logística y actualiza el estado a medida que avanza.</p>

<% if (!items || items.length === 0) { %>
  <div class="card"><p class="muted">Todavía no hay ofrecimientos de equipos.</p></div>
<% } %>

<% items.forEach(it => { %>
  <div class="card" style="display:flex; gap:20px;">
    <div style="flex:0 0 140px;">
      <% if (it.photo) { %>
        <img src="/api/equipment-donations/<%= it.id %>/photo" alt="Foto del equipo" style="width:140px; height:140px; object-fit:cover; border-radius:10px; border:1px solid var(--border);">
      <% } else { %>
        <div style="width:140px; height:140px; border-radius:10px; border:1px dashed var(--border); display:flex; align-items:center; justify-content:center; color:var(--body); font-size:12px; text-align:center;">Sin foto</div>
      <% } %>
    </div>
    <div style="flex:1;">
      <div style="display:flex; justify-content:space-between; align-items:start;">
        <div>
          <h3 style="margin:0 0 4px;"><%= it.item_type || 'Equipo' %> <% if (it.model) { %>— <%= it.model %><% } %></h3>
          <div class="muted"><%= new Date(it.created_at).toLocaleDateString('es-VE') %> · Cantidad: <%= it.quantity %></div>
        </div>
        <span class="badge <%= it.status === 'received' ? 'badge-public' : (it.status === 'coordinating' ? '' : 'badge-private') %>" style="<% if(it.status==='coordinating'){ %>background:#FFF4E0;color:#B36B00;<% } %>">
          <%= it.status === 'pending' ? 'Pendiente' : (it.status === 'coordinating' ? 'Coordinando' : 'Recibido') %>
        </span>
      </div>

      <table style="margin-top:12px;">
        <tr><td style="width:160px;font-weight:600;">Contacto</td><td><%= it.donor_name || '—' %><% if(it.donor_email){ %> · <%= it.donor_email %><% } %><% if(it.donor_phone){ %> · <%= it.donor_phone %><% } %></td></tr>
        <tr><td style="font-weight:600;">Estado del equipo</td><td><%= it.condition_desc || '—' %></td></tr>
        <tr><td style="font-weight:600;">Valor aproximado</td><td><%= it.estimated_value ? '$' + Number(it.estimated_value).toLocaleString('en-US') : '—' %></td></tr>
        <tr><td style="font-weight:600;">Detalles</td><td style="white-space:pre-wrap;"><%= it.description || '—' %></td></tr>
      </table>

      <div style="display:flex; gap:10px; margin-top:14px; align-items:center;">
        <form method="POST" action="/admin/equipment/<%= it.id %>/status" class="inline">
          <select name="status" onchange="this.form.submit()" style="width:auto;display:inline-block;margin-bottom:0;">
            <% EQUIPMENT_STATUS_OPTIONS.forEach(s => { %>
              <option value="<%= s %>" <%= it.status === s ? 'selected' : '' %>>
                <%= s === 'pending' ? 'Pendiente' : (s === 'coordinating' ? 'Coordinando' : 'Recibido') %>
              </option>
            <% }) %>
          </select>
        </form>
        <form class="inline" method="POST" action="/admin/equipment/<%= it.id %>/delete" onsubmit="return confirm('¿Eliminar este ofrecimiento?')">
          <button type="submit" class="danger">Eliminar</button>
        </form>
      </div>
    </div>
  </div>
<% }) %>

<%- include('partials/layout-foot') %>
